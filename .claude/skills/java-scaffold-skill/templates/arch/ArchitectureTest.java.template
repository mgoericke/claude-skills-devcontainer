/**
 * Architecture tests for {{GROUP_ID}}.
 *
 * <p>Enforces BCE layer separation, naming conventions and clean imports
 * at build time. If a test fails, an architecture rule has been violated.
 *
 * <p>Framework: Taikai (based on ArchUnit)
 *
 * @author Development Team
 * @author Co-Author: Claude (claude-sonnet-4-6, Anthropic) – generated via java-scaffold-skill
 * @see <a href="https://github.com/enofex/taikai">Taikai</a>
 * @see <a href="https://www.archunit.org">ArchUnit</a>
 */
package {{GROUP_ID}};

import com.enofex.taikai.Taikai;
import com.tngtech.archunit.core.domain.JavaClasses;
import com.tngtech.archunit.core.importer.ClassFileImporter;
import com.tngtech.archunit.core.importer.ImportOption;
import com.tngtech.archunit.lang.ArchRule;
import org.junit.jupiter.api.Test;

import static com.tngtech.archunit.lang.syntax.ArchRuleDefinition.classes;

class ArchitectureTest {

    private static final String BASE_PACKAGE = "{{GROUP_ID}}";

    private final JavaClasses importedClasses = new ClassFileImporter()
            .withImportOption(ImportOption.Predefined.DO_NOT_INCLUDE_TESTS)
            .importPackages(BASE_PACKAGE);

    @Test
    void shouldFollowJavaConventions() {
        Taikai.builder()
                .namespace(BASE_PACKAGE)
                .java(java -> java
                        .noUsageOfDeprecatedAPIs()
                        .methodsShouldNotDeclareGenericExceptions()
                        .imports(imports -> imports
                                .shouldHaveNoCycles()
                                .shouldNotImport("..internal..")
                        )
                        .naming(naming -> naming
                                .classesShouldNotMatch(".*Impl")
                                .interfacesShouldNotHavePrefixI()
                                .constantsShouldFollowConventions()
                        )
                )
                .build()
                .check();
    }

    @Test
    void shouldFollowBCELayerRules() {
        Taikai.builder()
                .namespace(BASE_PACKAGE)
                .java(java -> java
                        .imports(imports -> imports
                                // entity layer must NOT depend on boundary
                                .shouldNotImport(BASE_PACKAGE + ".boundary..")
                        )
                )
                .build()
                .check();
    }

    @Test
    void controllersShouldResideInBoundaryRest() {
        ArchRule rule = classes()
                .that().haveSimpleNameEndingWith("Controller")
                .or().haveSimpleNameEndingWith("Resource")
                .should().resideInAPackage("..boundary.rest..");
        rule.check(importedClasses);
    }

    @Test
    void consumersShouldResideInBoundaryMessaging() {
        ArchRule rule = classes()
                .that().haveSimpleNameEndingWith("Consumer")
                .or().haveSimpleNameEndingWith("Listener")
                .should().resideInAPackage("..boundary.messaging..");
        rule.check(importedClasses);
    }

    @Test
    void servicesShouldResideInControl() {
        ArchRule rule = classes()
                .that().haveSimpleNameEndingWith("Service")
                .and().areNotAnnotatedWith("io.quarkiverse.langchain4j.RegisterAiService")
                .should().resideInAPackage("..control..");
        rule.check(importedClasses);
    }

    // ── AI layers (only relevant for LangChain4j projects) ──────────────

    @Test
    void aiServicesShouldResideInBoundaryAi() {
        ArchRule rule = classes()
                .that().areAnnotatedWith("io.quarkiverse.langchain4j.RegisterAiService")
                .should().resideInAPackage("..boundary.ai..");
        rule.check(importedClasses);
    }

    @Test
    void aiToolsShouldResideInControlAi() {
        ArchRule rule = classes()
                .that().containAnyMethodsThat(
                        com.tngtech.archunit.base.DescribedPredicate.describe(
                                "annotated with @Tool",
                                method -> method.isAnnotatedWith("dev.langchain4j.agent.tool.Tool")))
                .should().resideInAPackage("..control.ai..");
        rule.check(importedClasses);
    }
}
