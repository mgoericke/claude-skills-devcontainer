package {{GROUP_ID}}.boundary.ai;

import dev.langchain4j.service.SystemMessage;
import dev.langchain4j.service.UserMessage;
import dev.langchain4j.service.V;
import io.quarkiverse.langchain4j.Agent;
import io.quarkiverse.langchain4j.RegisterAiService;
import io.quarkiverse.langchain4j.ToolBox;
import jakarta.enterprise.context.ApplicationScoped;

import {{GROUP_ID}}.control.ai.{{TOOL_CLASS_NAME}};

@ApplicationScoped
@RegisterAiService
public interface {{AGENT_NAME}} {

    @SystemMessage("""
            You are a specialized agent for {{DOMAIN_DESCRIPTION}}.
            Use the available tools to solve the task autonomously.
            """)
    @UserMessage("{{AGENT_TASK_DESCRIPTION}}: {input}")
    @Agent("{{AGENT_DESCRIPTION}}")
    @ToolBox({{TOOL_CLASS_NAME}}.class)
    String process(@V("input") String input);
}
