/**
 * Agentic AI Service – autonomer Agent mit Tool-Zugriff.
 *
 * <p>Erstellt mit Quarkus 3.x · BCE-Architektur (Boundary-Schicht / AI)
 *
 * <p>Agents unterscheiden sich von einfachen AI Services:
 * <ul>
 *   <li>Ein Agent hat genau EINE Methode (Single Responsibility)
 *   <li>{@code @Agent} auf der Methode beschreibt den Agent fuer Workflow-Orchestrierung
 *   <li>{@code @RegisterAiService} auf dem Interface erzeugt den CDI-Bean
 *   <li>Agents koennen in Workflows kombiniert werden (Sequence, Parallel, Loop, Supervisor)
 * </ul>
 *
 * @author Development Team
 * @author Co-Author: Claude (claude-sonnet-4-6, Anthropic) – generiert via java-scaffold-skill
 * @see <a href="https://quarkus.io/blog/agentic-ai-patterns/">Agentic AI Patterns</a>
 */
package {{GROUP_ID}}.boundary.ai;

import dev.langchain4j.service.SystemMessage;
import dev.langchain4j.service.UserMessage;
import dev.langchain4j.service.V;
import io.quarkiverse.langchain4j.Agent;
import io.quarkiverse.langchain4j.RegisterAiService;
import io.quarkiverse.langchain4j.ToolBox;
import jakarta.enterprise.context.ApplicationScoped;

import {{GROUP_ID}}.control.ai.{{TOOL_CLASS_NAME}};

@ApplicationScoped
@RegisterAiService
public interface {{AGENT_NAME}} {

    @SystemMessage("""
            Du bist ein spezialisierter Agent fuer {{DOMAIN_DESCRIPTION}}.
            Nutze die verfuegbaren Tools, um die Aufgabe selbststaendig zu loesen.
            """)
    @UserMessage("{{AGENT_TASK_DESCRIPTION}}: {input}")
    @Agent("{{AGENT_DESCRIPTION}}")
    @ToolBox({{TOOL_CLASS_NAME}}.class)
    String process(@V("input") String input);
}
