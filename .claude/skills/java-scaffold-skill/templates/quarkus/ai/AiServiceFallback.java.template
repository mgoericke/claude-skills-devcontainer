package {{GROUP_ID}}.control.ai;

import io.quarkus.logging.Log;
import org.eclipse.microprofile.faulttolerance.ExecutionContext;
import org.eclipse.microprofile.faulttolerance.FallbackHandler;
import jakarta.enterprise.context.ApplicationScoped;

@ApplicationScoped
public class {{AI_SERVICE_NAME}}Fallback implements FallbackHandler<String> {

    @Override
    public String handle(ExecutionContext context) {
        Log.errorf("AI Service nicht erreichbar: %s", context.getFailure().getMessage());
        return "Der AI-Assistent ist derzeit nicht verfuegbar. Bitte versuchen Sie es spaeter erneut.";
    }
}
