# Dockerfile.jvm – {{ARTIFACT_ID}} (JVM / Fast-JAR)
# Speicherort: src/main/docker/Dockerfile.jvm
#
# Co-Author: Claude (claude-sonnet-4-6, Anthropic)
#
# Build via Maven (empfohlen):
#   ./mvnw package -DskipTests
#   docker build -f src/main/docker/Dockerfile.jvm -t {{ARTIFACT_ID}}:jvm .
#
# Alternativ direkt: docker build -f src/main/docker/Dockerfile.jvm -t {{ARTIFACT_ID}}:jvm .

FROM eclipse-temurin:25-jre-alpine
WORKDIR /app
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

# Quarkus Fast-JAR Struktur
COPY --chown=appuser:appgroup target/quarkus-app/lib/ lib/
COPY --chown=appuser:appgroup target/quarkus-app/*.jar .
COPY --chown=appuser:appgroup target/quarkus-app/app/ app/
COPY --chown=appuser:appgroup target/quarkus-app/quarkus/ quarkus/

EXPOSE 8080
# Health Check über Quarkus SmallRye Health /q/health
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO- http://localhost:8080/q/health/live | grep '"status":"UP"' || exit 1
ENTRYPOINT ["java", "-jar", "quarkus-run.jar"]
