/**
 * Document ingestion for RAG – loads documents into the vector database.
 *
 * <p>Created with Quarkus 3.x · BCE architecture (Control layer / AI)
 *
 * <p>Executed at application startup ({@code @Startup}).
 * Documents are split into segments, embedded as vectors
 * and stored in the EmbeddingStore (PgVector).
 *
 * @author Development Team
 * @author Co-Author: Claude (claude-sonnet-4-6, Anthropic) – generated via java-scaffold-skill
 */
package {{GROUP_ID}}.control.ai;

import dev.langchain4j.data.document.Document;
import dev.langchain4j.data.document.splitter.DocumentSplitters;
import dev.langchain4j.model.embedding.EmbeddingModel;
import dev.langchain4j.store.embedding.EmbeddingStore;
import dev.langchain4j.store.embedding.EmbeddingStoreIngestor;
import io.quarkus.logging.Log;
import io.quarkus.runtime.Startup;
import jakarta.enterprise.context.ApplicationScoped;
import jakarta.inject.Inject;
import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.List;

@ApplicationScoped
public class {{RAG_INGESTION_CLASS}} {

    @Inject
    EmbeddingStore embeddingStore;

    @Inject
    EmbeddingModel embeddingModel;

    @Startup
    public void ingest() {
        Log.info("Starting document ingestion...");

        var ingestor = EmbeddingStoreIngestor.builder()
                .embeddingStore(embeddingStore)
                .embeddingModel(embeddingModel)
                .documentSplitter(DocumentSplitters.recursive(500, 50))
                .build();

        List<Document> documents = loadDocuments();
        ingestor.ingest(documents);

        Log.infof("Document ingestion completed: %d documents processed", documents.size());
    }

    private List<Document> loadDocuments() {
        // TODO: Load documents from the desired directory
        // Example: Markdown files from src/main/resources/documents/
        Path documentsDir = Path.of("src/main/resources/documents");
        try (var paths = Files.list(documentsDir)) {
            return paths
                    .filter(p -> p.toString().endsWith(".md") || p.toString().endsWith(".txt"))
                    .map(this::loadDocument)
                    .toList();
        } catch (IOException e) {
            Log.warn("Documents directory not found: " + documentsDir, e);
            return List.of();
        }
    }

    private Document loadDocument(Path path) {
        try {
            return Document.from(Files.readString(path));
        } catch (IOException e) {
            throw new RuntimeException("Error loading file: " + path, e);
        }
    }
}
